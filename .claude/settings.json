{
  "permissions": {
    "ask": [
      "Bash(git commit*)",
      "Bash(git add*)",
      "Bash(git push*)",
      "Bash(git reset*)",
      "Bash(git checkout -- *)",
      "Bash(git restore*)",
      "Bash(git rebase*)",
      "Bash(git merge*)",
      "Bash(git stash*)",
      "Bash(git branch -D*)",
      "Bash(git branch -d*)",
      "Bash(git tag*)",
      "Bash(git cherry-pick*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/ruff-format.sh",
            "timeout": 10000
          }
        ]
      },
      {
        "matcher": "MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/ruff-format.sh",
            "timeout": 10000
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/ruff-format.sh",
            "timeout": 10000
          }
        ]
      }
    ]
  }
}
